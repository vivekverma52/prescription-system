# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=prescription_db

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_64chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_64chars
JWT_REFRESH_EXPIRES=7d

# ── Superadmin JWT ────────────────────────────────────────────────────────────
SUPERADMIN_JWT_SECRET=your_superadmin_jwt_secret

# ── Superadmin credentials ────────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=your_superadmin_password

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_s3_bucket_name

# ── AWS SQS ───────────────────────────────────────────────────────────────────
# Producer: receives { imageKey, patientId } after prescription image upload
SQS_UPLOAD_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/613628041067/video-processing-receive-queue
# Consumer: backend polls this queue for processed results { imageKey, interpretedData }
SQS_RESULT_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/613628041067/OCR-result
# Producer: receives full render payload when pharmacist clicks Render
SQS_RENDER_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/613628041067/my-standard-queue

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@yourdomain.com
SMTP_PASS="your_password"
MAIL_FROM="Medscript <your_email@yourdomain.com>"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=900
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
